using System;
using System.Collections.Generic;
using System.ComponentModel;
using System.Data;
using System.Drawing;
using System.Linq;
using System.Text;
using System.Threading.Tasks;
using System.Windows.Forms;

namespace KalkulatorGeometri
{
    public partial class Form1 : Form
    {
        public struct Riwayat
        {
            public string NamaBangun;
            public double Luas;
        }

        Riwayat[] data = new Riwayat[100];
        int jumlahData = 0;

        public Form1()
        {
            InitializeComponent();

            btnHitung.Click += btnHitung_Click;
            btnReset.Click += btnReset_Click;
            btnSorting.Click += btnSorting_Click;
            btnKeluar.Click += btnKeluar_Click;
        }

        private void btnHitung_Click(object sender, EventArgs e)
        {
            try
            {
                double luas = 0;
                double keliling = 0;
                double volume = 0;

                switch (cmbBangun.Text)
                {
                    case "Persegi":
                        {
                            double sisi = Convert.ToDouble(txtSisi.Text);

                            if (sisi <= 0)
                            {
                                MessageBox.Show("Sisi harus lebih dari 0");
                                return;
                            }

                            luas = sisi * sisi;
                            keliling = 4 * sisi;
                            break;
                        }

                    case "Persegi Panjang":
                        {
                            double p = Convert.ToDouble(txtPanjang.Text);
                            double l = Convert.ToDouble(txtLebar.Text);

                            luas = p * l;
                            keliling = 2 * (p + l);
                            break;
                        }

                    case "Lingkaran":
                        {
                            double r = Convert.ToDouble(txtJari.Text);

                            luas = Math.PI * r * r;
                            keliling = 2 * Math.PI * r;
                            break;
                        }

                    case "Segitiga":
                        {
                            double alas = Convert.ToDouble(txtPanjang.Text);
                            double tinggi = Convert.ToDouble(txtTinggi.Text);

                            luas = 0.5 * alas * tinggi;
                            break;
                        }

                    case "Kubus":
                        {
                            double sisi = Convert.ToDouble(txtSisi.Text);

                            luas = 6 * sisi * sisi;
                            volume = sisi * sisi * sisi;
                            break;
                        }

                    case "Balok":
                        {
                            double p = Convert.ToDouble(txtPanjang.Text);
                            double l = Convert.ToDouble(txtLebar.Text);
                            double t = Convert.ToDouble(txtTinggi.Text);

                            luas = 2 * ((p * l) + (p * t) + (l * t));
                            volume = p * l * t;
                            break;
                        }

                    case "Tabung":
                        {
                            double r = Convert.ToDouble(txtJari.Text);
                            double t = Convert.ToDouble(txtTinggi.Text);

                            luas = 2 * Math.PI * r * (r + t);
                            volume = Math.PI * r * r * t;
                            break;
                        }

                    default:
                        MessageBox.Show("Pilih bangun terlebih dahulu!");
                        return;
                }

                lblLuas.Text = luas.ToString("0.00");
                lblKeliling.Text = keliling.ToString("0.00");
                lblVolume.Text = volume.ToString("0.00");

                if (jumlahData < data.Length)
                {
                    data[jumlahData].NamaBangun = cmbBangun.Text;
                    data[jumlahData].Luas = luas;

                    lstRiwayat.Items.Add(
                        cmbBangun.Text +
                        " | Luas = " +
                        luas.ToString("0.00"));

                    jumlahData++;
                }
            }
            catch
            {
                MessageBox.Show("Masukkan angka yang valid!");
            }
        }

        private void btnReset_Click(object sender, EventArgs e)
        {
            txtSisi.Clear();
            txtPanjang.Clear();
            txtLebar.Clear();
            txtTinggi.Clear();
            txtJari.Clear();

            lblLuas.Text = "0";
            lblKeliling.Text = "0";
            lblVolume.Text = "0";

            cmbBangun.SelectedIndex = -1;

            txtSisi.Focus();
        }

        private void btnSorting_Click(object sender, EventArgs e)
        {
            for (int i = 0; i < jumlahData - 1; i++)
            {
                for (int j = i + 1; j < jumlahData; j++)
                {
                    if (data[i].Luas > data[j].Luas)
                    {
                        Riwayat temp = data[i];
                        data[i] = data[j];
                        data[j] = temp;
                    }
                }
            }

            lstRiwayat.Items.Clear();

            for (int i = 0; i < jumlahData; i++)
            {
                lstRiwayat.Items.Add(
                    data[i].NamaBangun +
                    " | Luas = " +
                    data[i].Luas.ToString("0.00"));
            }

            MessageBox.Show("Data berhasil diurutkan berdasarkan luas.");
        }

        private void btnKeluar_Click(object sender, EventArgs e)
        {
            DialogResult hasil = MessageBox.Show(
                "Yakin ingin keluar?",
                "Konfirmasi",
                MessageBoxButtons.YesNo,
                MessageBoxIcon.Question);

            if (hasil == DialogResult.Yes)
            {
                Application.Exit();
            }
        }

        private void lstRiwayat_SelectedIndexChanged(object sender, EventArgs e)
        {
            // Currently no behavior needed when selection changes.
            // Keep method to satisfy Designer event subscription.
        }
    }
}
